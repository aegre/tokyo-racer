# Supabase Configuration
# Get these values from your Supabase project settings (Project Settings → API)

# Project URL (can be public)
SUPABASE_URL=https://your-project.supabase.co
# Or use PUBLIC_SUPABASE_URL if you prefer the PUBLIC_ prefix

# Service Role Key (SECRET - never expose to client!)
# This is for server-side operations only
# Get from: Project Settings → API → service_role key (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Note: For client-side operations, you would use:
# SUPABASE_PUBLISHABLE_KEY or PUBLIC_SUPABASE_ANON_KEY
# But this app runs server-side, so we use service_role key

# Email Configuration (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Email sender address
# For development, use Resend's test domain: onboarding@resend.dev
# For production, use your verified domain: noreply@yourdomain.com
FROM_EMAIL=onboarding@resend.dev

# Your app URL (for verification links)
# In development: http://localhost:4321
# In production: https://your-domain.com
APP_URL=http://localhost:4321
