---
import '../styles/global.css';
import { getUserFromSession } from '../lib/session';

// Check if user is authenticated
let user = null;
let isAuthenticated = false;

try {
	const sessionToken = Astro.cookies.get('session')?.value;
	if (sessionToken) {
		user = await getUserFromSession(sessionToken);
		isAuthenticated = !!user;
	}
} catch (error) {
	console.error('Authentication check error:', error);
	isAuthenticated = false;
}

// Redirect to login if not authenticated
if (!isAuthenticated) {
	return Astro.redirect('/login', 302);
}
---

<!DOCTYPE html>
<html lang="en" data-theme="professional">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Tokyo Tracker - Profile</title>
		<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
	</head>
	<body class="min-h-screen bg-gradient-to-br from-base-200 via-base-100 to-base-200">
		<header class="topbar">
			<div class="topbar-overlay" id="topbarOverlay"></div>
			<div class="topbar-content">
				<div class="topbar-brand">
					<a href="/" class="topbar-logo">Tokyo Tracker</a>
				</div>
				<button class="topbar-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="topbar-icon" id="menuIcon">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
					</svg>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="topbar-icon" id="closeIcon" style="display: none;">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
				<nav class="topbar-nav" id="topbarNav">
					<a href="/" class="topbar-nav-link">Wanderers</a>
					<a href="/tips" class="topbar-nav-link">General Tips</a>
					<a href="/cars" class="topbar-nav-link">Mandatory Cars</a>
				</nav>
				<div class="topbar-actions">
					<div class="topbar-user">
						<button class="topbar-avatar" id="userMenuBtn" aria-label="User menu">
							<span class="topbar-avatar-text">{user?.username?.charAt(0).toUpperCase() || 'U'}</span>
						</button>
						<div class="topbar-dropdown" id="userMenu" style="display: none;">
							<a href="/profile" class="topbar-dropdown-item topbar-dropdown-item--active">
								Profile
							</a>
							<a href="/settings" class="topbar-dropdown-item">Settings</a>
							<a href="/api/logout" class="topbar-dropdown-item topbar-dropdown-item--danger">Logout</a>
						</div>
					</div>
				</div>
			</div>
		</header>

		<main class="dashboard">
			<div class="container">
				<!-- Page Header -->
				<div class="page-header">
					<div>
						<h1 class="page-title">Profile</h1>
						<p class="page-subtitle">Your progress and statistics</p>
					</div>
				</div>

				<!-- User Info Card -->
				<div class="stats-card">
					<div class="profile-header">
						<div class="profile-avatar">
							<span class="profile-avatar-text">{user?.username?.charAt(0).toUpperCase() || 'U'}</span>
						</div>
						<div class="profile-info">
							<h2 class="profile-username">{user?.username || 'User'}</h2>
							<p class="profile-email">{user?.email || ''}</p>
							<div class="profile-meta">
								<span class="profile-badge" id="emailVerifiedBadge">
									{user?.email_verified ? '✓ Verified' : '⚠ Unverified'}
								</span>
								<span class="profile-meta-text" id="memberSince">Member since: Loading...</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Stats Grid -->
				<div class="stats-grid">
					<!-- Rivals Progress Card -->
					<div class="stats-card">
						<div class="stats-card-header">
							<h3 class="stats-card-title">Rivals Progress</h3>
						</div>
						<div class="stats-card-content">
							<div class="stats-chart-container">
								<canvas id="rivalsChart"></canvas>
							</div>
							<div class="stats-details">
								<div class="stat-item">
									<span class="stat-label">Completed</span>
									<span class="stat-value" id="rivalsCompleted">0</span>
								</div>
								<div class="stat-item">
									<span class="stat-label">Pending</span>
									<span class="stat-value" id="rivalsPending">0</span>
								</div>
								<div class="stat-item">
									<span class="stat-label">Total</span>
									<span class="stat-value" id="rivalsTotal">0</span>
								</div>
								<div class="stat-item stat-item--highlight">
									<span class="stat-label">Completion Rate</span>
									<span class="stat-value" id="rivalsCompletionRate">0%</span>
								</div>
							</div>
							<div class="stats-extra">
								<p class="stats-extra-text">Highest Level Defeated: <strong id="highestLevel">-</strong></p>
							</div>
						</div>
					</div>

					<!-- Cars Progress Card -->
					<div class="stats-card">
						<div class="stats-card-header">
							<h3 class="stats-card-title">Mandatory Cars</h3>
						</div>
						<div class="stats-card-content">
							<div class="stats-chart-container">
								<canvas id="carsChart"></canvas>
							</div>
							<div class="stats-details">
								<div class="stat-item">
									<span class="stat-label">Owned</span>
									<span class="stat-value stat-value--owned" id="carsOwned">0</span>
								</div>
								<div class="stat-item">
									<span class="stat-label">Unlocked</span>
									<span class="stat-value stat-value--unlocked" id="carsUnlocked">0</span>
								</div>
								<div class="stat-item">
									<span class="stat-label">Locked</span>
									<span class="stat-value stat-value--locked" id="carsLocked">0</span>
								</div>
								<div class="stat-item stat-item--highlight">
									<span class="stat-label">Completion Rate</span>
									<span class="stat-value" id="carsCompletionRate">0%</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Activity Timeline -->
				<div class="stats-card">
					<div class="stats-card-header">
						<h3 class="stats-card-title">Recent Activity</h3>
					</div>
					<div class="stats-card-content">
						<div class="activity-timeline" id="activityTimeline">
							<div class="activity-loading">
								<span class="loading loading-spinner loading-md"></span>
								<p>Loading activity...</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Data Export -->
				<div class="stats-card">
					<div class="stats-card-header">
						<h3 class="stats-card-title">Data Export</h3>
					</div>
					<div class="stats-card-content">
						<div class="export-section">
							<p class="export-description">Download your progress data in JSON or CSV format.</p>
							<div class="export-buttons">
								<button class="btn btn-primary" id="exportJsonBtn">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 1rem; height: 1rem; margin-right: var(--space-2);">
										<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
									</svg>
									Export JSON
								</button>
								<button class="btn btn-secondary" id="exportCsvBtn">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 1rem; height: 1rem; margin-right: var(--space-2);">
										<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
									</svg>
									Export CSV
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</main>

		<script>
			// Mobile menu toggle
			const mobileMenuToggle = document.getElementById('mobileMenuToggle');
			const topbarNav = document.getElementById('topbarNav');
			const topbarOverlay = document.getElementById('topbarOverlay');
			const menuIcon = document.getElementById('menuIcon');
			const closeIcon = document.getElementById('closeIcon');
			
			if (mobileMenuToggle && topbarNav && topbarOverlay) {
				mobileMenuToggle.addEventListener('click', (e) => {
					e.stopPropagation();
					const isOpen = topbarNav.classList.contains('mobile-open');
					
					if (isOpen) {
						topbarNav.classList.remove('mobile-open');
						topbarOverlay.classList.remove('mobile-open');
						if (menuIcon) menuIcon.style.display = 'block';
						if (closeIcon) closeIcon.style.display = 'none';
					} else {
						topbarNav.classList.add('mobile-open');
						topbarOverlay.classList.add('mobile-open');
						if (menuIcon) menuIcon.style.display = 'none';
						if (closeIcon) closeIcon.style.display = 'block';
					}
				});
				
				topbarOverlay.addEventListener('click', () => {
					topbarNav.classList.remove('mobile-open');
					topbarOverlay.classList.remove('mobile-open');
					if (menuIcon) menuIcon.style.display = 'block';
					if (closeIcon) closeIcon.style.display = 'none';
				});
				
				topbarNav.querySelectorAll('.topbar-nav-link').forEach((link) => {
					link.addEventListener('click', () => {
						topbarNav.classList.remove('mobile-open');
						topbarOverlay.classList.remove('mobile-open');
						if (menuIcon) menuIcon.style.display = 'block';
						if (closeIcon) closeIcon.style.display = 'none';
					});
				});
			}

			// User menu toggle
			const userMenuBtn = document.getElementById('userMenuBtn');
			const userMenu = document.getElementById('userMenu');
			if (userMenuBtn && userMenu) {
				userMenuBtn.addEventListener('click', (e) => {
					e.stopPropagation();
					const isVisible = userMenu.style.display !== 'none';
					userMenu.style.display = isVisible ? 'none' : 'block';
				});

				document.addEventListener('click', (e) => {
					if (userMenu && !userMenu.contains(e.target as Node) && !userMenuBtn?.contains(e.target as Node)) {
						userMenu.style.display = 'none';
					}
				});
			}

			// Load and display stats
			let rivalsChart: Chart | null = null;
			let carsChart: Chart | null = null;

			async function loadStats() {
				try {
					const response = await fetch('/api/profile/stats');
					const data = await response.json() as { stats?: any };
					
					if (!data.stats) {
						throw new Error('No stats data received');
					}

					const stats = data.stats;

					// Update account info
					const memberSinceEl = document.getElementById('memberSince');
					if (memberSinceEl && stats.account?.createdAt) {
						const date = new Date(stats.account.createdAt);
						memberSinceEl.textContent = `Member since: ${date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`;
					}

					// Update rivals stats
					document.getElementById('rivalsCompleted')!.textContent = stats.rivals.completed.toString();
					document.getElementById('rivalsPending')!.textContent = stats.rivals.pending.toString();
					document.getElementById('rivalsTotal')!.textContent = stats.rivals.total.toString();
					document.getElementById('rivalsCompletionRate')!.textContent = `${stats.rivals.completionRate}%`;
					document.getElementById('highestLevel')!.textContent = stats.rivals.highestLevel > 0 ? stats.rivals.highestLevel.toString() : '-';

					// Update cars stats
					document.getElementById('carsOwned')!.textContent = stats.cars.owned.toString();
					document.getElementById('carsUnlocked')!.textContent = stats.cars.unlocked.toString();
					document.getElementById('carsLocked')!.textContent = stats.cars.locked.toString();
					document.getElementById('carsCompletionRate')!.textContent = `${stats.cars.completionRate}%`;

					// Create rivals pie chart
					const rivalsCtx = document.getElementById('rivalsChart') as HTMLCanvasElement;
					if (rivalsCtx && typeof Chart !== 'undefined') {
						if (rivalsChart) rivalsChart.destroy();
						rivalsChart = new Chart(rivalsCtx, {
							type: 'pie',
							data: {
								labels: ['Completed', 'Pending'],
								datasets: [{
									data: [stats.rivals.completed, stats.rivals.pending],
									backgroundColor: [
										'rgba(52, 211, 153, 0.8)', // green (accent-2)
										'rgba(148, 163, 184, 0.8)', // gray
									],
									borderColor: [
										'rgba(52, 211, 153, 1)',
										'rgba(148, 163, 184, 1)',
									],
									borderWidth: 2,
								}],
							},
							options: {
								responsive: true,
								maintainAspectRatio: true,
								plugins: {
									legend: {
										position: 'bottom',
										labels: {
											color: '#e5e7eb', // Explicit light color for dark theme
											padding: 20,
											font: {
												size: 16,
												weight: '600',
												family: 'ui-sans-serif, system-ui, sans-serif',
											},
											usePointStyle: true,
											pointStyle: 'circle',
											boxWidth: 14,
											boxHeight: 14,
											generateLabels: (chart: any) => {
												const data = chart.data;
												if (data.labels.length && data.datasets.length) {
													return data.labels.map((label: string, i: number) => {
														const value = data.datasets[0].data[i];
														return {
															text: `${label} (${value})`,
															fillStyle: data.datasets[0].backgroundColor[i],
															strokeStyle: data.datasets[0].borderColor[i],
															lineWidth: 2,
															hidden: false,
															index: i,
															fontColor: '#e5e7eb',
															textStrokeColor: '#e5e7eb',
															textStrokeWidth: 0,
														};
													});
												}
												return [];
											},
										},
									},
									tooltip: {
										enabled: true,
										backgroundColor: 'rgba(26, 31, 46, 0.95)',
										titleColor: '#e5e7eb',
										bodyColor: '#e5e7eb',
										borderColor: 'rgba(148, 163, 184, 0.35)',
										borderWidth: 1,
										padding: 12,
										displayColors: true,
										callbacks: {
											label: (context: any) => {
												const label = context.label || '';
												const value = context.parsed || 0;
												const total = context.dataset.data.reduce((a: number, b: number) => a + b, 0);
												const percentage = ((value / total) * 100).toFixed(1);
												return `${label}: ${value} (${percentage}%)`;
											},
										},
									},
								},
							},
						});
					}

					// Create cars pie chart
					const carsCtx = document.getElementById('carsChart') as HTMLCanvasElement;
					if (carsCtx && typeof Chart !== 'undefined') {
						if (carsChart) carsChart.destroy();
						carsChart = new Chart(carsCtx, {
							type: 'pie',
							data: {
								labels: ['Owned', 'Unlocked', 'Locked'],
								datasets: [{
									data: [stats.cars.owned, stats.cars.unlocked, stats.cars.locked],
									backgroundColor: [
										'rgba(52, 211, 153, 0.8)', // green (owned)
										'rgba(96, 165, 250, 0.8)', // blue (unlocked)
										'rgba(71, 85, 105, 0.8)', // dark gray (locked)
									],
									borderColor: [
										'rgba(52, 211, 153, 1)',
										'rgba(96, 165, 250, 1)',
										'rgba(71, 85, 105, 1)',
									],
									borderWidth: 2,
								}],
							},
							options: {
								responsive: true,
								maintainAspectRatio: true,
								plugins: {
									legend: {
										position: 'bottom',
										labels: {
											color: '#e5e7eb', // Explicit light color for dark theme
											padding: 20,
											font: {
												size: 16,
												weight: '600',
												family: 'ui-sans-serif, system-ui, sans-serif',
											},
											usePointStyle: true,
											pointStyle: 'circle',
											boxWidth: 14,
											boxHeight: 14,
											generateLabels: (chart: any) => {
												const data = chart.data;
												if (data.labels.length && data.datasets.length) {
													return data.labels.map((label: string, i: number) => {
														const value = data.datasets[0].data[i];
														return {
															text: `${label} (${value})`,
															fillStyle: data.datasets[0].backgroundColor[i],
															strokeStyle: data.datasets[0].borderColor[i],
															lineWidth: 2,
															hidden: false,
															index: i,
															fontColor: '#e5e7eb',
															textStrokeColor: '#e5e7eb',
															textStrokeWidth: 0,
														};
													});
												}
												return [];
											},
										},
									},
									tooltip: {
										enabled: true,
										backgroundColor: 'rgba(26, 31, 46, 0.95)',
										titleColor: '#e5e7eb',
										bodyColor: '#e5e7eb',
										borderColor: 'rgba(148, 163, 184, 0.35)',
										borderWidth: 1,
										padding: 12,
										displayColors: true,
										callbacks: {
											label: (context: any) => {
												const label = context.label || '';
												const value = context.parsed || 0;
												const total = context.dataset.data.reduce((a: number, b: number) => a + b, 0);
												const percentage = ((value / total) * 100).toFixed(1);
												return `${label}: ${value} (${percentage}%)`;
											},
										},
									},
								},
							},
						});
					}

					// Display activity timeline
					displayActivityTimeline(stats.activity || []);
				} catch (error) {
					console.error('Error loading stats:', error);
					const container = document.querySelector('.container');
					if (container) {
						container.innerHTML = `
							<div class="section">
								<div style="text-align: center; padding: var(--space-8);">
									<p style="color: var(--danger);">Error loading profile data. Please refresh the page.</p>
								</div>
							</div>
						`;
					}
				}
			}

			// Display activity timeline
			function displayActivityTimeline(activities: any[]) {
				const timelineEl = document.getElementById('activityTimeline');
				if (!timelineEl) return;

				if (activities.length === 0) {
					timelineEl.innerHTML = `
						<div class="activity-empty">
							<p>No recent activity to display.</p>
						</div>
					`;
					return;
				}

				timelineEl.innerHTML = activities.map((activity, index) => {
					const date = new Date(activity.timestamp);
					const timeAgo = getTimeAgo(date);
					
					return `
						<div class="activity-item" style="animation-delay: ${index * 0.05}s">
							<div class="activity-icon">${activity.icon}</div>
							<div class="activity-content">
								<div class="activity-title">${escapeHtml(activity.title)}</div>
								<div class="activity-description">${escapeHtml(activity.description)}</div>
								<div class="activity-time">${timeAgo}</div>
							</div>
						</div>
					`;
				}).join('');
			}

			// Helper function to get time ago
			function getTimeAgo(date: Date): string {
				const now = new Date();
				const diffMs = now.getTime() - date.getTime();
				const diffMins = Math.floor(diffMs / 60000);
				const diffHours = Math.floor(diffMs / 3600000);
				const diffDays = Math.floor(diffMs / 86400000);

				if (diffMins < 1) return 'Just now';
				if (diffMins < 60) return `${diffMins} minute${diffMins !== 1 ? 's' : ''} ago`;
				if (diffHours < 24) return `${diffHours} hour${diffHours !== 1 ? 's' : ''} ago`;
				if (diffDays < 7) return `${diffDays} day${diffDays !== 1 ? 's' : ''} ago`;
				
				return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: date.getFullYear() !== now.getFullYear() ? 'numeric' : undefined });
			}

			// Helper function to escape HTML
			function escapeHtml(text: string): string {
				const div = document.createElement('div');
				div.textContent = text;
				return div.innerHTML;
			}

			// Export functionality
			document.getElementById('exportJsonBtn')?.addEventListener('click', () => {
				window.location.href = '/api/profile/export?format=json';
			});

			document.getElementById('exportCsvBtn')?.addEventListener('click', () => {
				window.location.href = '/api/profile/export?format=csv';
			});

			// Initial load
			loadStats();
		</script>
	</body>
</html>
